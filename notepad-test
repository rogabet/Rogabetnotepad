def duotucpdf2dantupdf():
    #new
    import fitz  # PyMuPDF
    from PIL import Image, ImageEnhance
    import io
    import os

    def compress_pdf_with_enhancement(input_path, output_path, target_dpi=135):
        """
        压缩PDF文件并增强文字和盖章的清晰度
        确保输出文件比原文件小
        """

        def enhance_image(image):
            """增强图像的对比度和锐度"""
            # 转换为PIL图像
            img_pil = Image.frombytes("RGB", [image.width, image.height], image.samples)

            # 增强对比度
            enhancer = ImageEnhance.Contrast(img_pil)
            img_pil = enhancer.enhance(1.3)  # 提高对比度

            # 增强锐度
            enhancer = ImageEnhance.Sharpness(img_pil)
            img_pil = enhancer.enhance(2.0)  # 加强锐化

            return img_pil

        def process_pdf(dpi):
            """处理PDF的核心函数"""
            doc = fitz.open(input_path)
            output_doc = fitz.open()

            for page_num in range(len(doc)):
                page = doc[page_num]

                # 设置缩放比例以达到目标DPI
                zoom = dpi / 72.0  # 72是默认DPI
                mat = fitz.Matrix(zoom, zoom)

                # 渲染页面为图像
                pix = page.get_pixmap(matrix=mat)

                # 增强图像
                enhanced_img = enhance_image(pix)

                # 创建新的页面
                new_page = output_doc.new_page(width=page.rect.width * zoom,
                                               height=page.rect.height * zoom)

                # 将增强后的图像插入新页面
                img_byte_arr = io.BytesIO()
                enhanced_img.save(img_byte_arr, format='PNG')
                img_byte_arr.seek(0)

                # 插入图像到页面
                new_page.insert_image(new_page.rect, stream=img_byte_arr.getvalue())

            # 保存文档
            output_doc.save(output_path, garbage=4, deflate=True)
            output_doc.close()
            doc.close()

        # 初始处理
        initial_dpi = target_dpi
        process_pdf(initial_dpi)

        # 检查文件大小
        original_size = os.path.getsize(input_path)
        output_size = os.path.getsize(output_path)

        # 如果输出文件不小于原始文件，则降低DPI重试
        while output_size >= original_size:
            # 降低DPI以进一步压缩
            initial_dpi -= 10
            if initial_dpi < 50:  # 设置最低DPI限制
                break
            process_pdf(initial_dpi)
            output_size = os.path.getsize(output_path)

        # 如果仍然没有减小，尝试其他压缩方法
        if output_size >= original_size:
            # 使用fitz直接压缩PDF而不转换为图片
            doc = fitz.open(input_path)
            doc.save(output_path, garbage=4, deflate=True, linear=True)
            doc.close()

            output_size = os.path.getsize(output_path)

            # 如果还是不够小，尝试更激进的压缩
            if output_size >= original_size:
                # 再次尝试更低的DPI
                final_dpi = 100
                while output_size >= original_size and final_dpi >= 72:
                    process_pdf(final_dpi)
                    output_size = os.path.getsize(output_path)
                    final_dpi -= 5

    def compress_pdf(input_path, output_path):
        """
        主函数：选择PDF并进行压缩处理
        """
        if not input_path.lower().endswith('.pdf'):
            raise ValueError("输入文件必须是PDF格式")

        if not os.path.exists(input_path):
            raise FileNotFoundError(f"找不到输入文件: {input_path}")

        # 执行压缩和增强
        compress_pdf_with_enhancement(input_path, output_path)

        original_size = os.path.getsize(input_path)
        final_size = os.path.getsize(output_path)

        print(f"原始文件大小: {original_size} 字节")
        print(f"压缩后文件大小: {final_size} 字节")
        print(f"压缩率: {((original_size - final_size) / original_size) * 100:.2f}%")

        return output_path

    # 使用示例
    in_path = askopenfilename(title='选一个PDF文件准备压缩', defaultextension='.pdf')
    out_path = asksaveasfilename(initialfile='新图像pdf', defaultextension='.pdf')

    compress_pdf(in_path, out_path)
    showinfo('notice', '循环优化压缩PDF完毕')


