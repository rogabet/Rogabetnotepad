            # 打开文件并上传
            with open(file_path, 'rb') as file:
                ftp.storbinary(f"STOR {file_name}", file)

            # 关闭FTP连接
            ftp.quit()

            # 构造文件的URL地址
            file_url = urljoin(BASE_URL, file_name)
            return file_url

