    def manyxlsxs_manysheets2afile_inmanysheets():
        import pandas as pd
        import os
        from tkinter.filedialog import askdirectory, asksaveasfilename
        from tkinter.messagebox import showinfo

        showinfo('提示',
                 '选择一个等待合并表格的文件夹，再选择保存文件名，就会把 这个文件夹里 这些 多文件多子表合并到新文件多子表.')
        workwhere2bghb = askdirectory(title='选择数据来源文件夹') + '/'
        dir = str(workwhere2bghb)

        # 获取目录下所有的xlsx文件
        origin_file_list = [f for f in os.listdir(dir) if f.endswith('.xlsx')]
        print(origin_file_list)

        outhebingxlsx = asksaveasfilename(initialfile='未命名2-合并工作簿.xlsx', defaultextension='.xlsx',
                                          filetypes=[('xlsx files', '.xlsx')])

        with pd.ExcelWriter(outhebingxlsx) as writer:
            # 循环遍历表格
            for filename in origin_file_list:
                file_path = os.path.join(dir, filename)

                # 读取Excel文件中的所有sheet
                excel_file = pd.ExcelFile(file_path)
                sheet_names = excel_file.sheet_names

                # 遍历每个sheet
                for sheet_name in sheet_names:
                    # 读取特定sheet的数据
                    df = pd.read_excel(file_path, sheet_name=sheet_name)

                    # 创建新的sheet名称：原文件名(不含扩展名) + 原sheet名称
                    base_filename = filename[:-5] if filename.endswith('.xlsx') else filename
                    new_sheet_name = f"{base_filename}_{sheet_name}"

                    # 确保sheet名称不超过31个字符（Excel限制）
                    if len(new_sheet_name) > 31:
                        new_sheet_name = new_sheet_name[:31]

                    # 写入数据
                    string = "".join(list(str(i) for i in df.index))
                    # 判断如果索引都为数字，则不保留索引
                    if string.isdigit():
                        df.to_excel(writer, new_sheet_name, index=False)
                    else:
                        df.to_excel(writer, new_sheet_name)

        showinfo('notice', '多表件多卡->工作簿-合并完毕！')
    buttonhbfilessheets = ttk.Button(top6manybiaoczpl, text="多文件多子表合到单件多子表(工作簿)",width=46, command=manyxlsxs_manysheets2afile_inmanysheets)
