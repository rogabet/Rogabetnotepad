def tujinbiaopl():
    showinfo('提示', '选1个文件夹，里边只放要插入表的图片，保存打开表格，它会包含那些图.选表内一个图，再ctrl+a全选所有图，右击-切换为嵌入单元格图片R即可')
    import xlsxwriter
    import os.path
    from PIL import Image
    import tkinter.filedialog as fd

    pilfanyiwhere = askdirectory() + '/'  # 批量翻译文档来源
    t1yibdleftxlsxframe.delete(0.0, 'end')
    t1yibdleftxlsxframe.insert(0.0, pilfanyiwhere)

    try:
        os.remove(pilfanyiwhere + 'desktop.ini')
    except:
        pass

    piliangfanyitaskwhere = t1yibdleftxlsxframe.get(0.0, 'end').replace('\n', '')
    UI_ROOT = piliangfanyitaskwhere

    # 询问保存位置
    save_path = fd.asksaveasfilename(
        title="保存表格",
        defaultextension=".xlsx",
        filetypes=[("Excel files", "*.xlsx"), ("All files", "*.*")]
    )

    if not save_path:
        return  # 用户取消操作

    # Create an new Excel file and add a worksheet.
    workbook = xlsxwriter.Workbook(save_path)
    worksheet = workbook.add_worksheet()

    # 设置列宽
    worksheet.set_column('A:A', 5)
    worksheet.set_column('B:B', 30)
    worksheet.set_column('C:C', 20)

    # 设置第一行文字
    red_format = workbook.add_format({'bold': True, 'font_color': 'red'})
    red_format.set_align('center')
    worksheet.write('A1', r'序号', red_format)
    worksheet.write('B1', r'路径', red_format)
    worksheet.write('C1', r'图片', red_format)

    # 居中格式
    v_format = workbook.add_format()
    v_format.set_align('center')
    v_format.set_align('vcenter')

    row_index = 2
    for root, dirs, files in os.walk(UI_ROOT):
        for file in files:
            img_path = root + '/' + file
            if 'DS_Store' not in img_path and file.lower().endswith(('.jpg', '.jpeg', '.png', '.bmp', '.gif')):
                img = Image.open(img_path)
                print(img_path, img.height, img.width, row_index)

                # 设置固定行高以适应3厘米的图片
                row_height = 100  # 约3厘米的高度（大约28像素/厘米 * 3）
                worksheet.set_row(row_index - 1, row_height)  # 设置行高度

                worksheet.write('A{}'.format(row_index), row_index - 1, v_format)
                worksheet.write('B{}'.format(row_index), img_path, v_format)

                # 计算缩放比例以使图片为3厘米宽高
                # Excel中大约28像素约等于1厘米，所以3厘米约为84像素
                target_width = 100
                target_height = 100

                x_scale = target_width / img.width
                y_scale = target_height / img.height
                scale = min(x_scale, y_scale)  # 保持宽高比，使用较小的比例

                worksheet.insert_image('C{}'.format(row_index), img_path, {
                    'object_position': 1,
                    'x_scale': scale,
                    'y_scale': scale,
                    'x_offset': 0,
                    'y_offset': 0
                })

                row_index += 1

    print('row_index', row_index)
    workbook.close()

    # 打开生成的文件
    os.startfile(save_path)

