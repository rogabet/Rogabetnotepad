                domain_workgroup = "域=%s" % system.Domain
            else:
                domain_workgroup = "域=%s" % system.Domain
            list.append("**加入的域或工作组: %s" % domain_workgroup)
            list.append("\n")

        # BIOS信息
        for bios in c.Win32_BIOS():
            list.append("**Bios描述: %s" % bios.Description)
