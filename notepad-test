from pathlib import Path
def killrepeatfiles():
    def killrepeatfiles_thread():
        # 选择目录
        default_directory = os.path.join(os.environ['USERPROFILE'], 'Documents', 'WeChat Files')
        root_path = askdirectory(title="选择清理目录，删除重复文件", initialdir=default_directory)
        if not root_path:
            showinfo("提示", "未选择目录，操作取消。")
            return

        # 存储所有文件的 md5 值和路径
        md5_dict = {}

        total_files = 0
        deleted_files = 0

        # 遍历所有文件（递归）
        for file_path in Path(root_path).rglob('*'):
            if file_path.is_file():
                total_files += 1
                try:
                    # 计算文件 MD5
                    md5 = get_md5(file_path)
                    if md5 in md5_dict:
                        # 已存在相同文件，删除当前文件
                        file_path.unlink()
                        deleted_files += 1
                    else:
                        # 记录该文件
                        md5_dict[md5] = file_path
                except Exception as e:
                    print(f"处理文件 {file_path} 出错: {e}")

        showinfo(
            "提示",
            f"目录及子目录重复内容清理完毕。\n"
            f"文件总数：{total_files}\n"
            f"删除个数：{deleted_files}"
        )

    def get_md5(file_path):
        hash_md5 = hashlib.md5()
        with open(file_path, "rb") as f:
            for chunk in iter(lambda: f.read(4096), b""):
                hash_md5.update(chunk)
        return hash_md5.hexdigest()

    # 启动线程执行
    threadlenlaji21 = Thread(target=killrepeatfiles_thread)
    threadlenlaji21.start()
def manyolddoc2docx():
    from win32com import client as wc
    word = wc.Dispatch('Word.Application')
    # 将docx文件保存的路径
    # docxPath =workwhere3wzsbwb_laodoc
    # # doc文件路径
    # path = workwhere2wzsbtp_laodoc

    # 将docx文件保存的路径
    docxPath = e1workwherewzsbwb_laowendang.get()
    # doc文件路径
    path = e1workwherewzsbtp_laowendang.get()
    '''
    获取doc文件名，创建docx文件路径
    '''

    def getFileName(path):
        filesList = []
        for root, dirs, files in os.walk(path):
            isExists = os.path.exists(docxPath)
            # 新建docx文件夹
            if not isExists:
                os.makedirs(docxPath)
            for file in files:
                if file.endswith('doc') or file.endswith('DOC'):
                # 判断尾缀是不是doc
                    suffix = file.split('.')[1]
                    if suffix == 'doc'or 'DOC':
                        filesList.append(file)
            print(filesList)
            return filesList
    '''
    将doc文件转换成docx文件
    '''
    def docToDocx(fileNameList):
        try:
            for fileName in fileNameList:

                print("开始处理     文件名：" + fileName)
                doc = word.Documents.Open(path + '\\' + fileName)
                # [:-4]的意思是选这个字符串从开始到最后倒数第4位（不含）
                docxNamePath = docxPath + '\\' + fileName[:-4] + '.docx'
                print('转换完成！' + docxNamePath)
                doc.SaveAs(docxNamePath, 12, False, "", True, "", False, False, False, False)
        finally:
            # 一定要记得关闭docx，否则会出现文件占用
            doc.Close()

    try:
        fileNameList = getFileName(path)
        docToDocx(fileNameList)
    finally:
        word.Quit()
        showinfo('提示', '文件处理完毕')
