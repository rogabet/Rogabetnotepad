def manypptx2jpg():
    showinfo('注意', '先选择pptx位置.再选择输出jpg位置.')
    ppt_root = askdirectory(title='选择pptx位置') + '/'
    jpg_root = askdirectory(title='选择输出jpg位置') + '/'

    def ppt2png(pptFileName):
        powerpoint = win32com.client.Dispatch('PowerPoint.Application')
        powerpoint.Visible = True
        ppt_path = ppt_root + pptFileName
        ppt = powerpoint.Presentations.Open(ppt_path)
        ppt.SaveAs(jpg_root + pptFileName.rsplit('.')[0] + '_result.jpg', 17)
        ppt.Close()
        powerpoint.Quit()

    for fn in (fns for fns in os.listdir(ppt_root) if fns.endswith(('.ppt', 'pptx'))):
        ppt2png(fn)
    runingpb()
    showinfo('注意', '批量pptx转jpg完毕..')
def manypptx2pdf():
    showinfo('注意', '先选择pptx位置.')
    ppt_root = askdirectory(title='选择pptx位置') + '/'
    # jpg_root = askdirectory(title='选择输出jpg位置') + '/'
    def ppt2pdf(filename, output_filename):
        ppt_app = win32com.client.Dispatch('PowerPoint.Application')
        ppt = ppt_app.Presentations.Open(filename)
        ppt.SaveAs(output_filename, 32)
        print("导出成pdf格式成功!!!")
        ppt_app.Quit()
    dirname = ppt_root
    filenames = os.listdir(dirname)
    for filename in filenames:   # 判断文件的类型，对所有的ppt文件进行处理(ppt文件以ppt或者pptx结尾的)
        if filename.endswith('ppt') or filename.endswith('pptx'):
            base, ext = filename.split('.')  # base=PPT素材1 ext=pdf
            new_name = base + '.pdf'  # PPT素材1.pdf
            filename = dirname + '/' + filename
            output_filename = dirname + '/' + new_name
            ppt2pdf(filename, output_filename)
    runingpb()
    showinfo('注意', '批量pptx转pdf完毕.输出的pdf在ppt同目录.')
