        #
        # ]

        # 创建新的DataFrame
        product_names = []
        specifications = []

        for item in data_col:
            if pd.isna(item):
                product_names.append("")
                specifications.append("")
                continue

            item_str = str(item).strip()

            # 尝试匹配已知产品类型
            found_match = False
            for product in known_products:
                if item_str.startswith(product):
                    product_name = product
                    spec_part = item_str[len(product):].strip()

                    # 移除可能的连接符
                    if spec_part.startswith(" ") or spec_part.startswith("-") or spec_part.startswith("—"):
                        spec_part = spec_part[1:].strip()

                    product_names.append(product_name)
                    specifications.append(spec_part)
                    found_match = True
                    break

            if not found_match:
                # 通用方法：根据中文字符和参数进行切割
                # 首先尝试匹配常见规格模式
                pattern = r'(\d+(?:\.\d+)?)\s*(?:x|×|X)\s*(\d+(?:\.\d+)?)\s*(?:x|×|X)\s*(\d+(?:\.\d+)?)'
                match = re.search(pattern, item_str)

                if match:
                    # 找到了尺寸规格
                    start_pos = match.start()
                    product_part = item_str[:start_pos].strip()
                    spec_part = item_str[start_pos:].strip()
                    product_names.append(product_part)
                    specifications.append(spec_part)
                else:
                    # 查找其他可能的规格模式
                    other_patterns = [
                        r'(\d+(?:\.\d+)?)\s*mm',  # mm规格
                        r'(\d+(?:\.\d+)?)\s*cm',  # cm规格
                        r'(\d+(?:\.\d+)?)\s*m',  # m规格
                        r'(\d+(?:\.\d+)?)\s*kg',  # kg规格
                        r'(\d+(?:\.\d+)?)\s*A',  # A规格
                        r'(\d+(?:\.\d+)?)\s*V',  # V规格
                        r'(\d+(?:\.\d+)?)\s*W',  # W规格
                        r'(\d+(?:\.\d+)?)\s*MHz',  # MHz规格
                        r'(\d+(?:\.\d+)?)\s*Hz',  # Hz规格
                        r'(\d+(?:\.\d+)?)\s*N\.?m',  # N.m规格
                        r'(\d+(?:\.\d+)?)\s*\%',  # %规格
                        r'(\d+(?:\.\d+)?)\s*"',  # "规格
                    ]

                    spec_found = False
                    min_start_pos = float('inf')

                    for pat in other_patterns:
                        match = re.search(pat, item_str)
                        if match:
                            start_pos = match.start()
                            # 寻找最靠前的匹配位置
                            if start_pos < min_start_pos:
                                min_start_pos = start_pos
                                spec_found = True

                    if spec_found:
                        product_part = item_str[:min_start_pos].strip()
                        spec_part = item_str[min_start_pos:].strip()
                        product_names.append(product_part)
                        specifications.append(spec_part)
                    else:
                        # 通用中文切割逻辑
                        # 寻找中文字符和数字/符号的边界
                        # 匹配中文字符后跟数字或符号的模式
                        chinese_num_pattern = r'([\u4e00-\u9fff]+)([^\u4e00-\u9fff].*)$'
                        match = re.search(chinese_num_pattern, item_str)

                        if match:
                            product_part = match.group(1).strip()
                            spec_part = match.group(2).strip()
                            product_names.append(product_part)
                            specifications.append(spec_part)
                        else:
                            # 没有明显的中文和非中文分割点，尝试按空格分割
                            parts = item_str.split()
                            if len(parts) > 1:
                                # 尝试找出第一个包含中文字符的部分作为产品名
                                product_part = ""
                                spec_part = ""

                                for i, part in enumerate(parts):
                                    if re.search(r'[\u4e00-\u9fff]', part):
                                        product_part = " ".join(parts[:i + 1])
                                        spec_part = " ".join(parts[i + 1:])
                                        break

                                if not product_part:
                                    # 如果没找到中文部分，将前几个词作为产品名
                                    if len(parts) >= 2:
                                        product_part = " ".join(parts[:-1])
                                        spec_part = parts[-1]
                                    else:
                                        product_part = parts[0] if parts else ""
                                        spec_part = ""

                                product_names.append(product_part.strip())
                                specifications.append(spec_part.strip())
                            else:
                                # 只有一个词，全部作为产品名
                                product_names.append(item_str)
                                specifications.append("")

        # 创建结果DataFrame
        result_df = pd.DataFrame({
            '品名': product_names,
            '规格': specifications
        })

        # 保存到Excel
        with pd.ExcelWriter(output_path, engine='openpyxl') as writer:
            result_df.to_excel(writer, index=False, sheet_name='拆分结果')

        print(f"数据已成功拆分并保存到: {output_path}")
