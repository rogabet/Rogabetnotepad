def insertimg2wordmanya():
    showinfo('提示', '老的关键词输入后，新关键词输入某个图片地址，然后选择很多word所在文件夹，最后输出那些文档都把老的关键词换成图片了.')

    # file_path = workwhere
    file_path =e1workwhereth.get()
    file_list = os.listdir(file_path)
    def doOne(doc):
        old_keyword = e2oldword.get()
        img = e3newword.get()

        def center_insert_img(doc):
            # # 在单元格中插入图片
            for table in doc.tables:  # 遍历表格中的每一行
                for row in table.rows:   # 遍历行中的每一个单元格
                    for cell in row.cells:
                        if old_keyword in cell.text:
                            cell.text = cell.text.replace('\n', '')   # 替换单元格中的内容
                            cell.text = cell.text.replace(old_keyword, '')
                            run=cell.paragraphs[0].add_run('')
                            run.add_break()
                            run.add_picture(img, width=Inches(1.1))
            for paragraph in doc.paragraphs:
                # 根据文档中的占位符定位图片插入的位置
                if old_keyword in paragraph.text:
                    # 把占位符去掉
                    paragraph.text = paragraph.text.replace(old_keyword, '')
                    run = paragraph.add_run('')
                    run.add_break()
                    # 添加图片并指定大小
                    run.add_picture(img, width=Inches(1.5))

        doc2 = docx.Document(doc)  # 插入图片居中
        center_insert_img(doc2)  # 保存结果文件
        doc2.save(doc)

    dir_path = file_path
    files = os.listdir(path=dir_path)
    for file in files:
        try:
            print(os.path.join(dir_path, file))
            if '.docx' in file:
                doOne(os.path.join(dir_path, file))
            # print(os.path.join(dir_path, file))
            print("{}已经修改成功".format(file))
        except ValueError as e:
            print("{}发生如下错误\n{}".format(file, e))
    runingpb()
    showinfo('提示', '文件处理完毕')

