def change_liedeshunxu():
    import xlwings as xw
    import pandas as pd
    new_liedeshunxu=liedeshunxutxt.get(1.0, 'end').replace('\n','').replace('\t',' ')
    new_liedeshunxu2=new_liedeshunxu.split(' ')
    new_liedeshunxu2list=list(new_liedeshunxu2)
    print(new_liedeshunxu2list)
    column = new_liedeshunxu2list
    filenamepath=askopenfilename()
    app = xw.App(visible=False, add_book=False)
    workbook = app.books.open(filenamepath)
    worksheet = workbook.sheets
    data = []
    for i in worksheet:
        values = i.range('A1').expand().options(pd.DataFrame, index=False).value
        filtered = values[column]
        data.append(filtered)
    new_workbook = xw.books.add()
    new_worksheet = new_workbook.sheets.add('新排列顺序')
    new_worksheet.range('A1').value = pd.concat(data, ignore_index=False).set_index(column[0])
    outtiqushunxu=asksaveasfilename(initialfile='未命名-表.xlsx', defaultextension='.xlsx',filetypes=[('xlsx files', '.xlsx')])
    new_workbook.save(outtiqushunxu)
    workbook.close()
    app.quit()
    os.startfile(outtiqushunxu)
