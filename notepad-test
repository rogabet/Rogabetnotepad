                os.makedirs(self.output_dir)

            output_paths = []

            for i, image_path in enumerate(image_paths):
                self.progress_label.config(text=f"正在处理图片 {i + 1}/{len(image_paths)}...")
                self.root.update()

                # 生成输出文件名
                base_name = os.path.splitext(os.path.basename(image_path))[0]
                output_path = os.path.join(self.output_dir, f"{base_name}_no_watermark.png")

                # 调用去水印API
                result_path = self.call_watermark_api(image_path, output_path)
                if result_path:
                    output_paths.append(result_path)

            return output_paths

        def call_watermark_api(self, image_path, output_path):
            """调用去水印API"""
            try:
                # 创建任务
                headers = {'X-API-KEY': self.API_KEY}
                data = {'sync': '0'}
                files = {'file': open(image_path, 'rb')}
                url = 'https://techsz.aoscdn.com/api/tasks/visual/external/watermark-remove'

                response = requests.post(url, headers=headers, data=data, files=files)
                files['file'].close()

                response_json = response.json()
                if 'status' in response_json and response_json['status'] == 200:
                    if 'data' in response_json and 'task_id' in response_json['data']:
                        task_id = response_json['data']['task_id']
                        # 轮询任务结果
                        return self.poll_task_result(task_id, output_path)

            except Exception as e:
                print(f"处理图片时出错: {e}")
                return None

            return None

        def poll_task_result(self, task_id, output_path, timeout=30):
            """轮询任务结果"""
            headers = {'X-API-KEY': self.API_KEY}
            url = f'https://techsz.aoscdn.com/api/tasks/visual/external/watermark-remove/{task_id}'

            for i in range(timeout):
                try:
                    response = requests.get(url, headers=headers)
                    response_json = response.json()

                    if 'status' in response_json and response_json['status'] == 200:
                        if 'data' in response_json and 'state' in response_json['data']:
                            task_state = response_json['data']['state']
                            if task_state == 1:  # 任务成功
                                if 'file' in response_json['data']:
                                    file_url = response_json['data']['file']
                                    # 下载处理后的文件
                                    urllib.request.urlretrieve(file_url, output_path)
                                    return output_path
                            elif task_state < 0:  # 任务失败
                                break

                    time.sleep(1)

                except Exception as e:
                    print(f"轮询任务时出错: {e}")
                    break

            return None

        def images_to_pdf(self, image_paths):
            """将图片合并为PDF"""
            self.progress_label.config(text="正在合并PDF...")
            self.root.update()

            if not image_paths:
                return None

            # 创建输出PDF路径
            original_name = os.path.splitext(os.path.basename(self.pdf_path))[0]
            output_pdf_path = os.path.join(os.path.dirname(self.pdf_path), f"{original_name}_无水印.pdf")

            # 打开第一个图片作为基准
            image_list = []
            first_image = Image.open(image_paths[0])
            first_image = first_image.convert('RGB')

            # 添加其他图片
            for image_path in image_paths[1:]:
                img = Image.open(image_path)
                img = img.convert('RGB')
                image_list.append(img)

            # 保存为PDF
            first_image.save(output_pdf_path, save_all=True, append_images=image_list)

            return output_pdf_path

        def process_pdf(self):
            try:
                # 禁用按钮防止重复点击
                self.process_btn.config(state="disabled")
                self.select_pdf_btn.config(state="disabled")

                # 1. PDF转图片
                image_paths = self.pdf_to_images()
                if not image_paths:
                    showerror("错误", "PDF转换失败")
                    return

                # 2. 去除水印
                no_watermark_paths = self.remove_watermark(image_paths)
                if not no_watermark_paths:
                    showerror("错误", "水印去除失败")
                    return

                # 3. 合并为PDF
                final_pdf_path = self.images_to_pdf(no_watermark_paths)
                if not final_pdf_path:
                    showerror("错误", "PDF合并失败")
                    return

                self.progress_label.config(text="处理完成!")
                showinfo("完成", f"处理完成!\n文件保存在: {final_pdf_path}")
                # self.open_result_btn.config(state="normal")

            except Exception as e:
                showerror("错误", f"处理过程中出现错误: {str(e)}")
            finally:
                # 恢复按钮状态
                self.process_btn.config(state="normal")
                self.select_pdf_btn.config(state="normal")

