from pandas import read_csv
def csv2db():

    def replace_spaces_with_underscores(input_filename, output_filename):
        with open(input_filename, 'r', newline='') as csvfile, \
                open(output_filename, 'w', newline='') as outputfile:
            reader = csv.reader(csvfile)
            writer = csv.writer(outputfile)
            for row in reader:
                writer.writerow([col.replace(' ', '_') if isinstance(col, str) else col for col in row])

    # 假设有一个叫做data.csv的文件，我们需要将其中的空格替换为下划线
    replace_spaces_with_underscores('importplan.csv', 'importplan2.csv')

    #导入数据
    conn = sqlite3.connect("myplan.db")
    df = read_csv('importplan2.csv', encoding="GB2312")
    df.to_sql('pcmgr', conn, if_exists='append', index=False)
    runingpb()
    showinfo('notice', 'csv导入完毕.')
    time.sleep(1)
    os.remove('importplan2.csv')
