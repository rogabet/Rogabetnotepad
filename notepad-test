            list.append(
                "**内存厂商: %s" % memmodule.Manufacturer.replace('80AD000080AD', '海力士').replace('04CB', '威刚ADATA').replace('04C3', '威刚2ADATA').replace('029E', '三星Samsung').replace('04E8', '三星Samsung2').replace('04CD', '金士顿Kingston').replace('04D6', '金士顿2Kingston').replace('04E0', '金士顿3Kingston').replace('2C00', '美光Micron').replace('04A4', '英睿达Crucial美光子品牌').replace('014F', '东芝Toshiba').replace('04F0', '东芝2Toshiba2Kioxia').replace('04AC', '联想Lenovo').replace('08C8', 'Lenovo3thinkplus联想').replace('04B3', '东芝Toshiba3Kioxia').replace('04BA', 'SanDisk').replace('0425', '海康威视Hikvision').replace('80CE', 'SK_hynix海力士2').replace('8934', '长江存储').replace('8551', '铠侠').replace('048D', '光威Gloway'),)
            list.append("**内存型号: %s" % memmodule.PartNumber)
            list.append("**内存大小: %.2fGB" % (totalmemsize / 1024 ** 3))
            list.append("\n")
            try:
