def read_file_with_encoding(file_path):
    encodings = ['utf-8', 'gbk', 'utf-16']

    for encoding in encodings:
        try:
            with open(file_path, 'r', encoding=encoding) as file:
                content = file.read()
                return content
        except UnicodeDecodeError:
            continue

    return None

