def superfind():
    # 获取用户输入的起始和结束标记
    aa = entryvara.get()
    zz = entryvar2.get()

    #new
    highlighted_sentences = []  # 用于存储所有高亮的句子

    if aa !='':  # 获取文本框中的内容
        text = textPad.get(1.0, "end-1c")  # 去掉末尾的换行符
        # 构造正则表达式，匹配从 aa 到 zz 的内容
        pattern = re.compile(r"{}(.+?){}".format(re.escape(aa), re.escape(zz)))
        # 查找所有匹配项
        matches = list(pattern.finditer(text))
        # 遍历所有匹配项，检查是否连续
        for match in matches:
            start, end = match.span()  # 获取匹配的起始和结束位置
            # 检查匹配是否连续（即没有其他字符插入）
            if text[start:end] == match.group(0):
                # 对连续匹配的内容进行高亮
                tag_name = f"highlight_{start}_{end}"
                textPad.tag_config(tag_name, foreground="red")
                def search(text_widget, keyword, tag):
                    pos = '1.0'
                    while True:
                        idx = text_widget.search(keyword, pos, "end")
                        if not idx:
                            break
                        pos = f"{idx}+{len(keyword)}c"
                        text_widget.tag_add(tag, idx, pos)
                textPad.tag_add(tag_name, f"1.0 + {start} chars", f"1.0 + {end} chars")
                # 将高亮的句子添加到列表中
                highlighted_sentences.append(match.group(0))
            else:
                print(f"非连续匹配，忽略: {match.group(0)}")

        def save_highlighted_sentences(sentences):
            """
            保存高亮的句子到一个文本文件中，并询问用户保存位置。
            """
            # 打开文件保存对话框，让用户选择保存位置
            file_path = asksaveasfilename(
                defaultextension=".txt",
                filetypes=[("Text Files", "*.txt"), ("All Files", "*.*")],
                title="保存高亮句子"
            )
            if file_path:  # 如果用户选择了保存路径
                try:
                    with open(file_path, "w", encoding="utf-8") as file:
                        # 将所有高亮的句子写入文件，每句一行
                        file.write("\n".join(sentences))
                    print(f"高亮句子已保存到: {file_path}")
                except Exception as e:
                    print(f"保存失败: {e}")
            else:
                print("保存操作已取消。")
        if highlighted_sentences:
            save_highlighted_sentences(highlighted_sentences)

