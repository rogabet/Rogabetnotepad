    def split_product_data(file_path, output_path=None):
        """
        将包含品名规格的数据列拆分为品名和规格两列

        参数:
        file_path: 输入Excel文件路径
        output_path: 输出Excel文件路径，如果为None则在原文件名后添加'_split'
        """

        # 如果没有指定输出路径，则生成默认路径
        if output_path is None:
            if file_path.endswith('.xlsx'):
                output_path = file_path.replace('.xlsx', '_split.xlsx')
            else:
