    def myarc(t1, r, angle):
        arc_length = 2 * math.pi * r * angle / 360  # angle角度的扇形的弧长
        n = int(arc_length / 3) + 1  # 线段条数
        step_length = arc_length / n  # 每条线段的长度
        step_angle = angle / n  # 每条线段的角度
