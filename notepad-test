                sheet_count = len(wb.sheets())
                max_sheets = max(max_sheets, sheet_count)
                file_info_list.append((filename, wb))

        # 构建目标工作簿
        endwb = xlsxwriter.Workbook(end_xls)

        # 遍历每一个sheet编号（最多max_sheets）
        for sheet_idx in range(max_sheets):
            worksheet = endwb.add_worksheet(f'Sheet{sheet_idx + 1}')
            current_row = 0

            for filename, wb in file_info_list:
                data = get_sheet_data(wb, sheet_idx) if sheet_idx < len(wb.sheets()) else [[""]]
                for row in data:
                    for col_idx, cell in enumerate(row):
