        aa=v.get().split('...')[-2]
        zz=v.get().split('...')[-1]

    # 使用正则表达式提取符合条件的连续内容
    pattern = re.escape(aa) + r"(.+?)" + re.escape(zz)
    matches = re.finditer(pattern, textPad.get(1.0, END))

    # 清除之前的高亮标记
    textPad.tag_remove("highlight", "1.0", END)

    # 遍历匹配结果并高亮连续内容
    for match in matches:
        start_index = textPad.index(f"1.0 + {match.start()}c")  # 起始位置
        end_index = textPad.index(f"1.0 + {match.end()}c")  # 结束位置

        # 添加高亮标记
        textPad.tag_add("highlight", start_index, end_index)

    # 配置高亮样式
    textPad.tag_config("highlight", foreground="red")
    try:
        advsearchtxt()
    except:
        pass


