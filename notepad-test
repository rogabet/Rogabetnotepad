        def open_xls(file):
            try:
                fh = xlrd.open_workbook(directory + file)
                return fh
            except Exception as e:
                print("打开文件错误：" + str(e))
                return None

        def get_sheet_data(fh, sheet_index):
            try:
                sheet = fh.sheet_by_index(sheet_index)
                rows = []
                for rownum in range(sheet.nrows):
                    rows.append(sheet.row_values(rownum))
                return rows
            except IndexError:
