                    url = f'https://techsz.aoscdn.com/api/tasks/document/ocr/{task_id}'
                    for i in range(time_out):
                        if i != 0:
                            time.sleep(1)
                        response = requests.get(url, headers=headers)
                        response_json = response.json()
