            list.append("**操作系统版本号: %s" % os.Version)
            list.append("\n")

        # 计算机系统信息
        for system in c.Win32_ComputerSystem():
            list.append("**主机名: %s" % system.Caption)
            list.append("**用户名: %s" % system.UserName)
            # 域或工作组信息
            if system.DomainRole == 0:
