def toushibiao():
    import xlwings as xw
    import pandas as pd
    showinfo('样本举例', '以上 分别输入 销售金额（count） 销售地区（Case-Type） 销售分部（Case-State），然后选择 商品销售表（kpi-case），就会在每个子表里做出 透视表。')
    tsb_a=t1biaox1.get(1.0, 'end').replace('\n','')
    tsb_b=t2biaoy1.get(1.0,  'end').replace('\n','')
    tsb_c=t3biaoy2.get(1.0,  'end').replace('\n','')
    app = xw.App(visible=False, add_book=False)
    toushiPath = askopenfilename(defaultextension='.xlsx')
    workbook = app.books.open(toushiPath)
    worksheet = workbook.sheets
    for i in worksheet:
        values = i.range('A1').expand('table').options(pd.DataFrame).value
        pivottable = pd.pivot_table(values, values=tsb_a, index=tsb_b, columns=tsb_c, aggfunc='sum', fill_value=0,
                                    margins=True, margins_name='总计')
        i.range('Z1').value = pivottable
    workbook.save()
    workbook.close()
    app.quit()
    showinfo('提示', '操作完成,透视表在原表打开那页的Z1单元起步。')
