    def cut_excel_file(file_path, rows_per_file_body):
        # 提取文件名（不含扩展名）作为子目录名
        dir_name = os.path.splitext(os.path.basename(file_path))[0]
        target_dir = os.path.join(os.path.dirname(file_path), dir_name)
        os.makedirs(target_dir, exist_ok=True)

        # 读取Excel文件
        df = pd.read_excel(file_path)
        header = df.iloc[:0]  # 实际上这里不需要，因为to_excel会自动处理header

        # 注意：rows_per_file_body是不包括表头的行数
        # 切割数据并保存
        file_index = 1
        rows_to_skip = 0
        while rows_to_skip < len(df) - 1:  # 减1是因为我们要保留表头
            end_row = min(rows_to_skip + rows_per_file_body + 1, len(df))  # 加1是为了包含当前块的最后一行
            temp_df = df.iloc[rows_to_skip:end_row]
            # 每个新文件都包含源文件的第一行作为头部   # 但由于to_excel会自动处理header，我们只需要确保传递正确的DataFrame即可  # 创建文件名并保存
            file_name = f"part_{file_index}.xlsx"
            target_file_path = os.path.join(target_dir, file_name)
            temp_df.to_excel(target_file_path, index=False, header=True)  # header=True确保每个文件都有表头

            file_index += 1
            rows_to_skip += rows_per_file_body

