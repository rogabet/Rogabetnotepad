def shujub2ppttb():
    showinfo("提示", "选择一个数据表xlsx去生成图表折线图和饼图到ppt.")
    import pandas as pd
    from pptx import Presentation
    from pptx.chart.data import CategoryChartData
    from pptx.enum.chart import XL_CHART_TYPE
    from pptx.util import Inches
    file_path = askopenfilename(title='选一个表文件(如tabledata4-4y.xlsx)', defaultextension='.xlsx')
    df = pd.read_excel(file_path, engine='openpyxl')
    print(df)
    myPPT = Presentation()

    # 添加标题幻灯片
    slide_layout = myPPT.slide_layouts[0]
    slide = myPPT.slides.add_slide(slide_layout)
    title = slide.shapes.title
    subtitle = slide.placeholders[1]

    title.text = "分析报告"
    subtitle.text = "最近的数据"

    # 添加含有表格的幻灯片
    slide_layout = myPPT.slide_layouts[5]
    slide = myPPT.slides.add_slide(slide_layout)
    slide.shapes.title.text = '具体数据'

    # 将DataFrame转换为适合pptx使用的格式
    data = [df.columns.tolist()] + df.values.tolist()
    rows, cols = len(data), len(data[0])
    top, left, width, height = Inches(2.0), Inches(1.5), Inches(8), Inches(0.8)

    table = slide.shapes.add_table(rows, cols, left, top, width, height).table
    for r in range(rows):
        for c in range(cols):
            table.cell(r, c).text = str(data[r][c])

    # 添加图表的幻灯片
    slide = myPPT.slides.add_slide(slide_layout)
    slide.shapes.title.text = '可视化数据'

    chart_data = CategoryChartData()
    chart_data.categories = list(df.columns)[1:]  # 假设第一列是省份名称
    for index, row in df.iterrows():
        try:
            chart_data.add_series(row[0], (row[1], row[2], row[3], row[4]))
        except:
            chart_data.add_series(row[0], (row[1], row[2], row[3]))

    chart_type = XL_CHART_TYPE.LINE
    left, top, width, height = Inches(2), Inches(1.5), Inches(6), Inches(4.5)
    slide.shapes.add_chart(chart_type, left, top, width, height, chart_data)

    # 饼图
    # 添加饼图的幻灯片
    slide = myPPT.slides.add_slide(slide_layout)
    slide.shapes.title.text = '饼图展示'

    # 使用DataFrame的第一行（除去首列）作为示例数据
    example_row = df.iloc[0, 1:]  # 取第一行的数据，跳过第一列
    chart_data = CategoryChartData()
    chart_data.categories = list(df.columns)[1:]  # 假设第一列是省份名称
    for index, row in df.iterrows():
        try:
            chart_data.add_series(row[0], (row[1], row[2], row[3], row[4]))
        except:
            chart_data.add_series(row[0], (row[1], row[2], row[3]))

    chart_type = XL_CHART_TYPE.PIE
    left, top, width, height = Inches(2), Inches(1.5), Inches(6), Inches(4.5)
    slide.shapes.add_chart(chart_type, left, top, width, height, chart_data)
    outfilenameppttb = asksaveasfilename(initialfile='图表.pptx', defaultextension='.pptx',
                                    filetypes=[('pptx files', '.pptx')])
    myPPT.save(outfilenameppttb)
    # print('PPT文件已成功创建！')
    runingpb()
    os.startfile(outfilenameppttb)
